# Crunchtime Fitness Training API server environment placeholders.
# Backend/server values only. Do not copy these into artifacts/mobile/.env or Expo/EAS public env.

AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-primary-certificate
AGORA_TOKEN_EXPIRE_SECONDS=3600
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_CURRENCY=usd
STRIPE_PRICE_MEMBERSHIP_MONTHLY=price_membership_monthly
STRIPE_PRICE_BOOKING_ONE_HOUR=price_booking_one_hour
STRIPE_PRICE_CUSTOM_MEAL_PLAN=price_custom_meal_plan
STRIPE_PRICE_PREMIUM_WORKOUT_VIDEO=price_premium_workout_video
STRIPE_MEMBERSHIP_MONTHLY_PRICE_CENTS=800
STRIPE_BOOKING_ONE_HOUR_PRICE_CENTS=5000
STRIPE_CUSTOM_MEAL_PLAN_PRICE_CENTS=2500
STRIPE_PREMIUM_WORKOUT_VIDEO_PRICE_CENTS=800

# Legacy tier price IDs are still accepted only for backward-compatible old checkout calls.
STRIPE_PRICE_BRONZE_MONTHLY=price_bronze_monthly
STRIPE_PRICE_BRONZE_YEARLY=price_bronze_yearly
STRIPE_PRICE_SILVER_MONTHLY=price_silver_monthly
STRIPE_PRICE_SILVER_YEARLY=price_silver_yearly
STRIPE_PRICE_GOLD_MONTHLY=price_gold_monthly
STRIPE_PRICE_GOLD_YEARLY=price_gold_yearly
STRIPE_PRICE_PLATINUM_MONTHLY=price_platinum_monthly
STRIPE_PRICE_PLATINUM_YEARLY=price_platinum_yearly
PORT=3001
