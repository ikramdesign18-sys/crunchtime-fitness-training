# Crunchtime Fitness Training mobile environment placeholders.
# Public Expo app values only. Replace these in artifacts/mobile/.env and EAS public env.
# Never put service role keys, Agora certificates, token signing secrets, or GROQ_API_KEY here.

# Required: Supabase mobile client
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Required for live video calls
# Real Agora tokens/certificates must be generated server-side only.
# Physical Android APK testing must use your computer's LAN IP, not localhost.
EXPO_PUBLIC_API_BASE_URL=http://192.168.100.63:3001
EXPO_PUBLIC_VIDEO_CALL_PROVIDER=agora
EXPO_PUBLIC_AGORA_APP_ID=your-agora-app-id
