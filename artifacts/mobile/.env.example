# Crunchtime Fitness Training mobile environment placeholders.
# These are fake placeholder values only. Replace them in your local .env/EAS config.
# Never put service role keys, certificates, token signing secrets, or GROQ_API_KEY in Expo public env.

# Required: Supabase mobile client
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: live video call provider setup
# Real call tokens/certificates must be generated server-side only.
EXPO_PUBLIC_API_BASE_URL=http://192.168.100.63:3001
EXPO_PUBLIC_VIDEO_CALL_PROVIDER=agora
EXPO_PUBLIC_AGORA_APP_ID=your-agora-app-id
