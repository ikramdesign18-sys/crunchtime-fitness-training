{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "environment": "development",
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://crunchtime-fitness-training-api-ser-beta.vercel.app"
      }
    },
    "preview": {
      "environment": "preview",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://crunchtime-fitness-training-api-ser-beta.vercel.app"
      },
      "android": {
        "buildType": "apk"
      },
      "distribution": "internal"
    },
    "production": {
      "environment": "production",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://crunchtime-fitness-training-api-ser-beta.vercel.app"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
